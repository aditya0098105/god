@model IEnumerable<EarthDrive.Models.Customer>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<form asp-controller="Customers" asp-action="Index" method="get">
    <p>
        Search <input type="text" name="SearchString"/>
        <input type="submit" value="Filter"/>
    </p>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.cName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.cDob)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.cPhone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.cEmail)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.cName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.cDob)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.cPhone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.cEmail)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.cId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.cId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.cId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
